{
  "name": "projects-todo-advanced",
  "displayName": "Projects TODO Advanced",
  "description": "A structured TODO sidebar for VS Code with standalone lists, workspace visibility, drag and drop, and import/export.",
  "version": "1.0.0",
  "publisher": "greenpedro",
  "icon": "media/store/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pedogreen/TODO-Extension.git"
  },
  "homepage": "https://github.com/Pedogreen/TODO-Extension#readme",
  "bugs": {
    "url": "https://github.com/Pedogreen/TODO-Extension/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "todo",
    "tasks",
    "checklist",
    "sidebar",
    "productivity",
    "workspace",
    "project",
    "kanban",
    "organizer",
    "notes"
  ],
  "activationEvents": [
    "onView:todoListProView",
    "onCommand:todoListPro.createList",
    "onCommand:todoListPro.addGroup",
    "onCommand:todoListPro.addTodo",
    "onCommand:todoListPro.importAll",
    "onCommand:todoListPro.exportAll",
    "onCommand:todoListPro.exportSingleList",
    "onCommand:todoListPro.configureStorageMode",
    "onCommand:todoListPro.shareCurrentList",
    "onCommand:todoListPro.openListInEditor",
    "onCommand:todoListPro.addSharedList",
    "onCommand:todoListPro.copyLocalListToShareMode",
    "onCommand:todoListPro.syncSharedList",
    "onCommand:todoListPro.toggleAutoRefreshSharedLists",
    "onCommand:todoListPro.configureWorkspaceVisibility",
    "onCommand:todoListPro.configureCompletedRetention",
    "onCommand:todoListPro.setFilter",
    "onCommand:todoListPro.clearFilter",
    "onCommand:todoListPro.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todoListPro",
          "title": "TODO",
          "icon": "media/checklist.svg"
        }
      ]
    },
    "views": {
      "todoListPro": [
        {
          "id": "todoListProView",
          "name": "TODO List",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "todoListPro.createList",
        "title": "Create List"
      },
      {
        "command": "todoListPro.addGroup",
        "title": "TODO: Add Group"
      },
      {
        "command": "todoListPro.addTodo",
        "title": "TODO: Add TODO"
      },
      {
        "command": "todoListPro.configureWorkspaceVisibility",
        "title": "Workspace Visibility..."
      },
      {
        "command": "todoListPro.configureCompletedRetention",
        "title": "Completed Retention..."
      },
      {
        "command": "todoListPro.exportAll",
        "title": "Export All"
      },
      {
        "command": "todoListPro.exportSingleList",
        "title": "Export Single List..."
      },
      {
        "command": "todoListPro.configureStorageMode",
        "title": "Storage Mode..."
      },
      {
        "command": "todoListPro.shareCurrentList",
        "title": "Share List"
      },
      {
        "command": "todoListPro.openListInEditor",
        "title": "Open List in Editor"
      },
      {
        "command": "todoListPro.addSharedList",
        "title": "Add Shared List"
      },
      {
        "command": "todoListPro.copyLocalListToShareMode",
        "title": "Copy Local List to Share Mode"
      },
      {
        "command": "todoListPro.syncSharedList",
        "title": "Sync Shared List"
      },
      {
        "command": "todoListPro.toggleAutoRefreshSharedLists",
        "title": "Auto Refresh Shared Lists..."
      },
      {
        "command": "todoListPro.importAll",
        "title": "Import"
      },
      {
        "command": "todoListPro.setFilter",
        "title": "TODO: Set Filter"
      },
      {
        "command": "todoListPro.clearFilter",
        "title": "TODO: Clear Filter"
      },
      {
        "command": "todoListPro.refresh",
        "title": "Refresh",
        "icon": {
          "light": "media/action-refresh-light.svg",
          "dark": "media/action-refresh-dark.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "todoListPro.refresh",
          "when": "view == todoListProView",
          "group": "navigation@1"
        },
        {
          "command": "todoListPro.createList",
          "when": "view == todoListProView",
          "group": "navigation@2"
        },
        {
          "command": "todoListPro.openListInEditor",
          "when": "view == todoListProView",
          "group": "lists@10"
        },
        {
          "command": "todoListPro.shareCurrentList",
          "when": "view == todoListProView",
          "group": "sharing@10"
        },
        {
          "command": "todoListPro.addSharedList",
          "when": "view == todoListProView",
          "group": "sharing@20"
        },
        {
          "command": "todoListPro.syncSharedList",
          "when": "view == todoListProView",
          "group": "sharing@30"
        },
        {
          "command": "todoListPro.toggleAutoRefreshSharedLists",
          "when": "view == todoListProView",
          "group": "sharing@40"
        },
        {
          "command": "todoListPro.exportSingleList",
          "when": "view == todoListProView",
          "group": "data@10"
        },
        {
          "command": "todoListPro.exportAll",
          "when": "view == todoListProView",
          "group": "data@20"
        },
        {
          "command": "todoListPro.importAll",
          "when": "view == todoListProView",
          "group": "data@30"
        },
        {
          "command": "todoListPro.configureWorkspaceVisibility",
          "when": "view == todoListProView",
          "group": "settings@10"
        },
        {
          "command": "todoListPro.configureCompletedRetention",
          "when": "view == todoListProView",
          "group": "settings@20"
        },
        {
          "command": "todoListPro.configureStorageMode",
          "when": "view == todoListProView",
          "group": "settings@30"
        }
      ]
    },
    "configuration": {
      "title": "TODO List Pro",
      "properties": {
        "todoListPro.storageMode": {
          "type": "string",
          "enum": [
            "local",
            "github"
          ],
          "default": "local",
          "description": "Where TODO lists are stored."
        },
        "todoListPro.completedRetentionDays": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "description": "How many days completed TODOs stay before automatic deletion."
        },
        "todoListPro.autoRefreshSharedLists": {
          "type": "boolean",
          "default": false,
          "description": "Automatically refresh shared lists every 5 minutes when at least one shared list exists."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
